@startuml
!theme plain
title F1r3Drive Build System Configuration

package "Build System" {
  class BuildGradle <<UPDATE>> {
    + sourceSets.macos 🆕
    + sourceSets.linux 🆕
    + sourceSets.windows 🆕
    + buildMacOS task 🆕
    + buildLinux task 🆕
    + buildWindows task 🆕
    + platformVariant property 🆕
    --
    + shadowJar task 🔄
    + dependencies per platform 🆕
  }

  note right of BuildGradle : Add platform-specific\nsource sets and build tasks
}

package "Source Structure" {
  class MainSources {
    + src/main/java/
    + app packages ⚫
    + blockchain packages ⚫
    + filesystem packages ⚫
    + platform packages 🆕
    + placeholder packages 🆕
  }

  class MacOSSources {
    + src/macos/java/
    + platform.macos 🆕
  }

  class LinuxSources {
    + src/linux/java/
    + platform.linux 🆕
  }

  class WindowsSources {
    + src/windows/java/
    + platform.windows 🔮
  }
}

package "Output JARs" {
  class MacOSJar {
    + Common classes ⚫
    + macOS platform 🍎
    + No jnr-fuse dependency
    --
    Size: ~15MB
  }

  class LinuxJar {
    + Common classes ⚫
    + Linux platform 🐧
    + jnr-fuse binding ⚫
    --
    Size: ~18MB
  }

  class WindowsJar {
    + Common classes ⚫
    + Windows platform 🪟
    + WinFsp integration 🆕
    --
    Size: ~20MB
  }
}

package "Build Commands" as commands {
  note as macoscmd
    **macOS Build:**
    ./gradlew shadowJar -PplatformVariant=macos

    **Dependencies:**
    - No additional platform deps
    - Uses native macOS APIs
  end note

  note as linuxcmd
    **Linux Build:**
    ./gradlew shadowJar -PplatformVariant=linux

    **Dependencies:**
    - jnr-fuse:0.5.7
    - jnr-ffi for inotify
  end note

  note as wincmd
    **Windows Build:**
    ./gradlew shadowJar -PplatformVariant=windows

    **Dependencies:**
    - WinFsp library
    - Windows API bindings
  end note
}

BuildGradle --> MacOSJar : builds
BuildGradle --> LinuxJar : builds
BuildGradle --> WindowsJar : builds

MainSources --> MacOSJar
MacOSSources --> MacOSJar
MainSources --> LinuxJar
LinuxSources --> LinuxJar
MainSources --> WindowsJar
WindowsSources --> WindowsJar

macoscmd --> MacOSJar
linuxcmd --> LinuxJar
wincmd --> WindowsJar

@enduml
