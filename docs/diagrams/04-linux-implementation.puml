@startuml
!theme plain
title Linux Implementation (Linux JAR Only)

package "io.f1r3fly.f1r3drive.platform.linux" <<LINUX ONLY>> {

  class LinuxChangeWatcher <<NEW>> {
    - fuseFilesystem: FuseFilesystem
    - inotifyMonitor: InotifyMonitor
    - changeListener: ChangeListener
    - mountPath: String
    - isMonitoring: boolean
    - eventExecutor: ExecutorService
    - callbacks: Map<String, FileChangeCallback>
    - fuseThread: Thread

    + initialize(mountPath: String, listener: ChangeListener): void
    + startMonitoring(): void
    + stopMonitoring(): void
    + isMonitoring(): boolean
    + registerFileCallback(path: String, callback: FileChangeCallback): void
    + unregisterFileCallback(path: String): void
    + cleanup(): void
    + getPlatformInfo(): PlatformInfo
    + setMemoryFileSystem(fs: InMemoryFileSystem): void
    + setPlaceholderManager(manager: PlaceholderManager): void
    - handleInotifyEvent(event: InotifyEvent): void
    - handleFuseOperation(operation: FuseOperation): void
    - initializeFuseFilesystem(): void
    - initializeInotifyMonitor(): void
    - mountFuseFilesystem(): void
    - unmountFuseFilesystem(): void
  }

  class FuseFilesystem <<NEW>> {
    - f1r3filesystem: InMemoryFileSystem
    - callback: FuseOperationCallback
    - placeholderManager: PlaceholderManager
    - openFiles: Map<String, Integer>

    + getattr(path: String, stat: FileStat): int
    + readdir(path: String, buf: Pointer, filter: FuseFillDir, offset: long, fi: FuseFileInfo): int
    + open(path: String, fi: FuseFileInfo): int
    + read(path: String, buf: Pointer, size: long, offset: long, fi: FuseFileInfo): int
    + write(path: String, buf: Pointer, size: long, offset: long, fi: FuseFileInfo): int
    + create(path: String, mode: long, fi: FuseFileInfo): int
    + unlink(path: String): int
    + mkdir(path: String, mode: long): int
    + rmdir(path: String): int
    + truncate(path: String, size: long): int
    + flush(path: String, fi: FuseFileInfo): int
    + release(path: String, fi: FuseFileInfo): int
    + rename(oldPath: String, newPath: String): int
    + chmod(path: String, mode: long): int
    + chown(path: String, uid: long, gid: long): int
    - notifyOperation(path: String, type: FuseOperationType): void
    - loadPlaceholderContent(path: String): byte[]
  }

  class InotifyMonitor <<NEW>> {
    - inotifyFd: int
    - watchDescriptors: Map<Integer, String>
    - callback: InotifyCallback
    - monitorThread: Thread
    - isRunning: boolean
    - eventBuffer: ByteBuffer

    + startMonitoring(path: String, callback: InotifyCallback): void
    + addWatch(path: String, mask: int): void
    + removeWatch(path: String): void
    + stopMonitoring(): void
    + isRunning(): boolean
    + cleanup(): void
    - processInotifyEvents(): void
    - parseEvent(eventData: byte[]): InotifyEvent
    - createWatch(path: String): int
    - destroyWatch(wd: int): void
    - readInotifyEvents(): List<InotifyEvent>
  }

  class LinuxPlatformInfo <<NEW>> {
    + getPlatformName(): String
    + getVersion(): String
    + supportsFSEvents(): boolean
    + supportsFileProvider(): boolean
    + supportsFUSE(): boolean
    + supportsInotify(): boolean
    + getSupportedFeatures(): Set<String>
    + getKernelVersion(): String
    + getFuseVersion(): String
    + hasInotifySupport(): boolean
  }

  interface FuseOperationCallback <<NEW>> {
    + onOperation(path: String, operation: FuseOperationType): void
    + onFileAccess(path: String, accessType: AccessType): void
    + onError(path: String, error: Exception): void
  }

  interface InotifyCallback <<NEW>> {
    + onEvent(event: InotifyEvent): void
    + onError(error: InotifyException): void
  }

  class InotifyEvent <<NEW>> {
    + path: String
    + mask: int
    + cookie: int
    + name: String
    + timestamp: long

    + getPath(): String
    + getMask(): int
    + getCookie(): int
    + getName(): String
    + getTimestamp(): long
    + isCreated(): boolean
    + isModified(): boolean
    + isDeleted(): boolean
    + isAccessed(): boolean
    + isMoved(): boolean
  }

  class FuseOperation <<NEW>> {
    + path: String
    + operationType: FuseOperationType
    + data: byte[]
    + result: int

    + getPath(): String
    + getOperationType(): FuseOperationType
    + getData(): byte[]
    + getResult(): int
    + isSuccessful(): boolean
  }

  enum FuseOperationType <<NEW>> {
    GETATTR
    READDIR
    OPEN
    READ
    WRITE
    CREATE
    UNLINK
    MKDIR
    RMDIR
    TRUNCATE
    FLUSH
    RELEASE
    RENAME
  }

  enum InotifyMask <<NEW>> {
    IN_CREATE
    IN_MODIFY
    IN_DELETE
    IN_MOVED_FROM
    IN_MOVED_TO
    IN_OPEN
    IN_CLOSE_WRITE
    IN_CLOSE_NOWRITE
    IN_ACCESS
    IN_ATTRIB
  }

  exception InotifyException <<NEW>> {
    + InotifyException(message: String)
    + InotifyException(message: String, cause: Throwable)
  }

  exception FuseException <<NEW>> {
    + FuseException(message: String)
    + FuseException(message: String, cause: Throwable)
  }
}

package "JNR Integration" <<Linux Native>> {
  abstract class FuseStubFS <<jnr-fuse>> {
    {abstract} + getattr(path: String, stat: FileStat): int
    {abstract} + readdir(path: String, buf: Pointer, filter: FuseFillDir, offset: long, fi: FuseFileInfo): int
    {abstract} + open(path: String, fi: FuseFileInfo): int
    {abstract} + read(path: String, buf: Pointer, size: long, offset: long, fi: FuseFileInfo): int
  }

  class LibC <<jnr-ffi>> {
    + inotify_init1(flags: int): int
    + inotify_add_watch(fd: int, pathname: String, mask: int): int
    + inotify_rm_watch(fd: int, wd: int): int
    + read(fd: int, buf: Pointer, count: long): long
    + close(fd: int): int
  }

  class FuseMain <<jnr-fuse>> {
    + mount(filesystem: FuseStubFS, mountPoint: String, debug: boolean): void
    + unmount(mountPoint: String): void
  }

  note as jnrnote
    **JNR Dependencies:**
    - jnr-fuse:0.5.7
    - jnr-ffi:2.2.15
    - jnr-posix:3.1.18

    **Provides:**
    - FUSE kernel module access
    - Native Linux system calls
    - inotify API bindings
  end note
}

package "Linux Kernel" <<System>> {
  class "FUSE Module" <<Kernel>> {
    + Virtual filesystem interface
    + User-space filesystem support
    + File operation routing
  }

  class "inotify" <<Kernel>> {
    + File system event monitoring
    + Real-time notifications
    + Recursive directory watching
  }

  note as kernelnote
    **Linux Kernel Features:**
    - FUSE 2.6+ required
    - inotify support in kernel
    - Proper permissions needed
  end note
}

' Relationships
LinuxChangeWatcher ..|> ChangeWatcher : implements
LinuxChangeWatcher *-- FuseFilesystem : contains
LinuxChangeWatcher *-- InotifyMonitor : contains
LinuxChangeWatcher *-- LinuxPlatformInfo : creates

FuseFilesystem --|> FuseStubFS : extends
FuseFilesystem ..> FuseOperationCallback : uses
FuseFilesystem ..> FuseOperation : creates
FuseFilesystem ..> FuseOperationType : uses

InotifyMonitor ..> InotifyCallback : uses
InotifyMonitor ..> InotifyEvent : creates
InotifyMonitor ..> InotifyMask : uses
InotifyMonitor --> LibC : uses

FuseFilesystem --> FuseMain : mounted by
InotifyMonitor --> "inotify" : uses
FuseFilesystem --> "FUSE Module" : communicates with

InotifyEvent ..> InotifyMask : contains
FuseOperation ..> FuseOperationType : has

' Notes
note top of LinuxChangeWatcher : Main integration point\nfor Linux platform.\nUses FUSE + inotify

note right of FuseFilesystem : FUSE filesystem implementation.\nBridge between kernel FUSE\nand InMemoryFileSystem

note bottom of InotifyMonitor : File event monitoring\nthrough Linux inotify API.\nRuns asynchronously

note left of LinuxPlatformInfo : Information about Linux\nplatform capabilities.\nChecks FUSE and inotify

@enduml
