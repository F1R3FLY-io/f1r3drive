@startuml
!theme plain
title Placeholder Management System (Shared Component)

package "io.f1r3fly.f1r3drive.placeholder" <<NEW>> {

  class PlaceholderManager <<NEW>> {
    - placeholders: Map<String, PlaceholderInfo>
    - fileCallback: FileChangeCallback
    - loadingExecutor: ExecutorService
    - contentCache: Cache<String, byte[]>
    - cacheConfig: CacheConfiguration
    - loadingTasks: Map<String, CompletableFuture<byte[]>>
    - cacheStats: CacheStatistics

    + createPlaceholder(path: String, info: PlaceholderInfo): void
    + updatePlaceholder(path: String, content: byte[]): void
    + removePlaceholder(path: String): void
    + isPlaceholder(path: String): boolean
    + getPlaceholderInfo(path: String): PlaceholderInfo
    + loadContent(path: String): CompletableFuture<byte[]>
    + preloadContent(path: String): void
    + cacheContent(path: String, content: byte[]): void
    + clearCache(path: String): void
    + cleanup(): void
    + getCacheStatistics(): CacheStatistics
    + evictExpiredEntries(): void
    - handleLoadingError(path: String, error: Exception): void
    - validatePlaceholder(info: PlaceholderInfo): void
    - updateCacheStats(): void
    - schedulePreloading(path: String): void
  }

  class PlaceholderInfo <<NEW>> {
    - path: String
    - size: long
    - lastModified: long
    - blockchainAddress: String
    - state: PlaceholderState
    - metadata: Map<String, Object>
    - createdAt: long
    - lastAccessed: long
    - loadAttempts: int
    - priority: PlaceholderPriority

    + getPath(): String
    + getSize(): long
    + getLastModified(): long
    + getBlockchainAddress(): String
    + getState(): PlaceholderState
    + setState(state: PlaceholderState): void
    + getMetadata(key: String): Object
    + setMetadata(key: String, value: Object): void
    + isLoaded(): boolean
    + isLoading(): boolean
    + isError(): boolean
    + getCreatedAt(): long
    + getLastAccessed(): long
    + updateLastAccessed(): void
    + incrementLoadAttempts(): void
    + getLoadAttempts(): int
    + getPriority(): PlaceholderPriority
    + setPriority(priority: PlaceholderPriority): void
    + validate(): boolean
    + toJson(): String
    + fromJson(json: String): PlaceholderInfo
  }

  enum PlaceholderState <<NEW>> {
    NOT_LOADED
    LOADING
    LOADED
    ERROR
    CACHED
    EXPIRED
    EVICTED
    + isTransient(): boolean
    + canTransitionTo(newState: PlaceholderState): boolean
  }

  enum PlaceholderPriority <<NEW>> {
    LOW
    NORMAL
    HIGH
    CRITICAL
    + getWeight(): int
  }

  class CacheConfiguration <<NEW>> {
    - maxSize: long
    - maxMemorySize: long
    - expireAfterWrite: Duration
    - expireAfterAccess: Duration
    - refreshAfterWrite: Duration
    - evictionPolicy: EvictionPolicy
    - compressionEnabled: boolean

    + getMaxSize(): long
    + getMaxMemorySize(): long
    + getExpireAfterWrite(): Duration
    + getExpireAfterAccess(): Duration
    + getRefreshAfterWrite(): Duration
    + getEvictionPolicy(): EvictionPolicy
    + isCompressionEnabled(): boolean
    + validate(): boolean
    + toBuilder(): CacheConfigurationBuilder
  }

  enum EvictionPolicy <<NEW>> {
    LRU
    LFU
    FIFO
    RANDOM
    PRIORITY_BASED
  }

  class CacheStatistics <<NEW>> {
    - hitCount: long
    - missCount: long
    - loadCount: long
    - errorCount: long
    - evictionCount: long
    - totalLoadTime: long
    - averageLoadTime: double
    - currentSize: long
    - maxSize: long

    + getHitCount(): long
    + getMissCount(): long
    + getHitRate(): double
    + getMissRate(): double
    + getLoadCount(): long
    + getErrorCount(): long
    + getEvictionCount(): long
    + getTotalLoadTime(): long
    + getAverageLoadTime(): double
    + getCurrentSize(): long
    + getMaxSize(): long
    + reset(): void
    + snapshot(): CacheStatistics
  }

  interface PlaceholderLoadListener <<NEW>> {
    + onLoadStarted(path: String): void
    + onLoadCompleted(path: String, content: byte[]): void
    + onLoadFailed(path: String, error: Exception): void
    + onCacheHit(path: String): void
    + onCacheMiss(path: String): void
    + onEviction(path: String, reason: EvictionReason): void
  }

  enum EvictionReason <<NEW>> {
    SIZE_LIMIT_EXCEEDED
    TIME_EXPIRED
    ACCESS_TIME_EXPIRED
    MANUAL_EVICTION
    MEMORY_PRESSURE
  }

  class PlaceholderLoadTask <<NEW>> {
    - path: String
    - priority: PlaceholderPriority
    - callback: FileChangeCallback
    - startTime: long
    - timeoutMs: long

    + getPath(): String
    + getPriority(): PlaceholderPriority
    + getCallback(): FileChangeCallback
    + getStartTime(): long
    + getTimeoutMs(): long
    + isTimedOut(): boolean
    + execute(): CompletableFuture<byte[]>
  }

  exception PlaceholderException <<NEW>> {
    + PlaceholderException(message: String)
    + PlaceholderException(message: String, cause: Throwable)
    + PlaceholderException(path: String, message: String)
  }

  exception PlaceholderLoadException <<NEW>> {
    - path: String
    - loadAttempts: int

    + PlaceholderLoadException(path: String, message: String)
    + PlaceholderLoadException(path: String, message: String, cause: Throwable)
    + getPath(): String
    + getLoadAttempts(): int
  }

  exception CacheException <<NEW>> {
    + CacheException(message: String)
    + CacheException(message: String, cause: Throwable)
  }
}

package "Integration Points" {
  class FileChangeCallback <<EXISTING>> {
    + onDemandLoad(path: String): CompletableFuture<byte[]>
    + onPlaceholderUpdate(path: String, info: PlaceholderInfo): void
    + shouldCache(path: String): boolean
  }

  class InMemoryFileSystem <<EXISTING>> {
    + createFile(path: String, content: byte[]): File
    + getNode(path: String): Optional<Node>
    + delete(path: String): boolean
  }

  class F1r3flyBlockchainClient <<EXISTING>> {
    + readFile(path: String): CompletableFuture<byte[]>
    + writeFile(path: String, content: byte[]): CompletableFuture<String>
    + listFiles(directory: String): CompletableFuture<List<String>>
  }
}

' Relationships
PlaceholderManager *-- PlaceholderInfo : manages
PlaceholderManager *-- CacheConfiguration : uses
PlaceholderManager *-- CacheStatistics : maintains
PlaceholderManager *-- PlaceholderLoadTask : creates
PlaceholderManager ..> PlaceholderLoadListener : notifies
PlaceholderManager ..> FileChangeCallback : uses

PlaceholderInfo *-- PlaceholderState : has
PlaceholderInfo *-- PlaceholderPriority : has

CacheConfiguration *-- EvictionPolicy : uses

PlaceholderLoadListener ..> EvictionReason : receives

PlaceholderLoadTask *-- PlaceholderPriority : has
PlaceholderLoadTask ..> FileChangeCallback : uses

' Integration relationships
PlaceholderManager ..> InMemoryFileSystem : updates
FileChangeCallback ..> F1r3flyBlockchainClient : calls
PlaceholderManager --> FileChangeCallback : delegates to

' Notes
note top of PlaceholderManager : Central component for managing\nlazy loading of files from blockchain.\nSupports caching and priorities

note right of PlaceholderInfo : Placeholder file metadata.\nTracks state, priority\nand access statistics

note bottom of CacheConfiguration : Cache configuration with support\nfor various eviction policies\nand compression

note left of PlaceholderState : Placeholder file lifecycle\nstates.\nSupports transition validation

' Workflow note
note as workflow
  **Placeholder Workflow:**
  1. createPlaceholder() - create placeholder
  2. File access triggers loadContent()
  3. onDemandLoad() calls blockchain
  4. Content cached and returned
  5. PlaceholderInfo state updated
  6. Cache statistics updated
end note

workflow --> PlaceholderManager

@enduml
