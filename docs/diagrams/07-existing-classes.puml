' Relationships between existing classes
InMemoryFileSystem ..|> FileSystem : implements
InMemoryFileSystem *-- RootDirectory : contains
Node <|-- Directory : extends
Node <|-- File : extends
Directory <|-- RootDirectory : extends
Directory <|-- WalletDirectory : extends
RootDirectory *-- WalletDirectory : contains

F1r3flyBlockchainClient *-- BlockchainContext : uses
F1r3flyBlockchainClient *-- GrpcClient : uses
BlockchainContext *-- WalletInfo : contains
BlockchainContext *-- NetworkConfig : contains

BlockingEventQueue ..|> EventQueue : implements
StateChangeEvent *-- EventType : has
F1r3DriveError <|-- PathNotFound : extends
F1r3DriveError <|-- InvalidPath : extends
F1r3DriveError <|-- BlockchainError : extends
F1r3DriveError <|-- FileSystemError : extends

Node *-- FilePermissions : has
BlockchainContext *-- NetworkConfig : uses

note top of FileSystem : **CORE FILESYSTEM**\nEntire filesystem\nremains UNCHANGED

note right of F1r3flyBlockchainClient : **BLOCKCHAIN LAYER**\nEntire blockchain integration\nremains UNCHANGED

note bottom of EventQueue : **STATE MANAGEMENT**\nEvent system remains\nUNCHANGED (except\nStateChangeEventsManager)

note left of AESCipher : **UTILITY CLASSES**\nAll utilities, encryption\nand error handling\nremain UNCHANGED

